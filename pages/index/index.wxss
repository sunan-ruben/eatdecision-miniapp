/* 主容器 */
.container {
  padding: 30rpx;
  min-height: 100vh;
  background-color: #F5F5F5;
}

/* 头部 */
.header {
  text-align: center;
  padding: 40rpx 0 30rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #FF6B35;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 输入区域 */
.input-section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.input-group {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
  background-color: #FAFAFA;
}

.input:focus {
  border-color: #FF6B35;
}

/* 人数选择器 */
.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
  background-color: #FAFAFA;
}

.arrow {
  font-size: 22rpx;
  color: #999;
}

/* 推荐按钮 */
.btn-recommend {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background-color: #FF6B35;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
  margin-top: 10rpx;
}

.btn-recommend[disabled] {
  background-color: #FFAB8A;
  color: #fff;
}

/* 加载中 */
.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #E8E8E8;
  border-top-color: #FF6B35;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}

/* 错误提示 */
.error-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.error-icon {
  font-size: 80rpx;
}

.error-text {
  font-size: 28rpx;
  color: #E74C3C;
  margin-top: 16rpx;
  text-align: center;
}

/* 结果区域 */
.result-section {
  margin-top: 10rpx;
}

.result-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

/* 餐厅卡片 */
.restaurant-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.restaurant-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border-left: 6rpx solid #FF6B35;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.restaurant-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.restaurant-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF6B35;
}

.card-body {
  margin-top: 8rpx;
}

.restaurant-reason {
  font-size: 26rpx;
  color: #888;
  line-height: 1.5;
}

/* 空结果 */
.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-top: 16rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #BBB;
  margin-top: 8rpx;
}
